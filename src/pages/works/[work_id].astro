---
import type { CollectionEntry } from "astro:content";
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Separator from "../../components/Separator.astro";

export const getStaticPaths = async () => {
  // Fetch all works from the 'works' collection
  const works = await getCollection("works");

  // Map over the works to generate paths for each work's page
  const paths = works.map((work) => {
    return {
      params: { work_id: work.id }, // URL parameter for the work's ID
      props: { works, work }, // Pass the full work and all works as props
    };
  });

  // Return the generated paths to Astro for static page generation
  return paths;
};

type Props = {
  works: CollectionEntry<"works">[]; // Array of all works in the collection
  work: CollectionEntry<"works">; // Current work being rendered
};

const { works, work } = Astro.props; // Extract the works list and current work from the props

// Extract the ID of the current work
const work_id = work.id;

// Find the index of the current work in the works array
const currentWorkIndex = works.findIndex((w) => w.id === work_id);

// Calculate the index of the "next" work in the array (wrap around if at the last work)
const nextWorkIndex = (currentWorkIndex + 1) % works.length;

// Get the "next" work based on the calculated index
const nextWork = works[nextWorkIndex];

// Render the content of the current work (e.g., markdown or MDX)
const { Content } = await render(work);
---

<BaseLayout title={work.data.title}>
  <section>
    <header class="title-header">
      <h2>{work.data.title}</h2>
      <div>
        <a class="back" href="/">View all</a>
        <span class="faded">/</span>
        <a href={`/works/${nextWork.id}`}>Next work</a>
      </div>
    </header>
    <div class="content-wrap">
      <img
        class="image fade-in"
        src={work.data.image.src}
        alt={work.data.image.alt}
      />
      <div class="content">
        <Content />
      </div>
    </div>
  </section>
</BaseLayout>
<style>
  .content-wrap {
    grid-template-areas: "img" "content";
    grid-template-columns: 100%;
    @media screen and (min-width: 50em) {
      grid-template-columns: 30vw 1fr;
      grid-template-areas: "img content";
    }
  }
</style>
